# DeepAgents 环境配置示例
# 复制此文件为 .env 并填入您的 API 密钥

# ==================== LLM 提供者配置 ====================
# 选择使用的 LLM 提供者: deepseek, kimi2.5, glm4.7, aliyun, doubao
LLM_PROVIDER=deepseek

# ==================== DeepSeek 配置 ====================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# ==================== kimi2.5 配置 ====================
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=kimi2.5

# ==================== glm4.7 配置 ====================
GLM_API_KEY=your_glm_api_key_here
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_NAME=glm4.7

# ==================== 阿里云通义千问配置 ====================
ALIYUN_API_KEY=your_aliyun_api_key_here
ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL_NAME=qwen-turbo

# ==================== 火山引擎豆包配置 ====================
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_NAME=doubao-pro-32k-241215

# ==================== Tavily 搜索配置 ====================
# 用于网络搜索功能
TAVILY_API_KEY=your_tavily_api_key_here

# ==================== 通用配置 ====================
# 模型温度参数 (0.0-1.0)
TEMPERATURE=0.1

# 调试模式
DEBUG=False

# ==================== LangSmith 配置 (可选) ====================
# 用于追踪和调试 Agent 行为
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=x-deepagents
